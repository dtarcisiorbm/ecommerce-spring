				"text": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@loja.com\",\n  \"password\": \"admin123\"\n}"
			},
			"_type": "request"
		},
		{
			"_id": "req_admin_login",
			"parentId": "fld_auth",
